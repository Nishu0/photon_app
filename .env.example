# Copy this file to .env and fill in your values.
# Bun auto-loads .env — no dotenv required.
# Anything you set here becomes the default answer in `photon setup`,
# so you can just press Enter through the prompts.

# iMessage handle of the owner (phone with country code, or Apple ID email).
# This is the ONLY person photon will respond to.
PHOTON_OWNER_HANDLE=

# OpenRouter API key — https://openrouter.ai/keys
PHOTON_OPENROUTER_KEY=

# Any OpenRouter model slug.
PHOTON_MODEL=anthropic/claude-sonnet-4

# IANA timezone, e.g. Asia/Kolkata, America/New_York.
PHOTON_TIMEZONE=

# local  = drive the Messages app on this Mac (no credentials needed).
# cloud  = use Spectrum Cloud (needs PHOTON_PROJECT_ID + PHOTON_PROJECT_SECRET).
PHOTON_MODE=local

# Only needed when PHOTON_MODE=cloud.
# Get these from your Photon project dashboard.
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=

# Daily check-in times (24h HH:MM in your local timezone).
PHOTON_CADENCE_MORNING=08:15
PHOTON_CADENCE_AFTERNOON=13:30
PHOTON_CADENCE_EVENING=21:45
