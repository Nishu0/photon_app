# Copy this file to .env and fill in your values.
# Bun auto-loads .env — no dotenv required.
# Anything you set here becomes the default answer in `kodama setup`,
# so you can just press Enter through the prompts.
#
# Legacy PHOTON_* variables are still read as a fallback for one release
# so you don't have to re-configure. New installs should use KODAMA_*.

# iMessage handle of the owner (phone with country code, or Apple ID email).
# This is the ONLY person kodama will respond to.
KODAMA_OWNER_HANDLE=

# OpenRouter API key — https://openrouter.ai/keys
KODAMA_OPENROUTER_KEY=

# Any OpenRouter model slug.
KODAMA_MODEL=anthropic/claude-sonnet-4

# IANA timezone, e.g. Asia/Kolkata, America/New_York.
KODAMA_TIMEZONE=

# local  = drive the Messages app on this Mac (no credentials needed).
# cloud  = use Spectrum Cloud (needs KODAMA_PROJECT_ID + KODAMA_PROJECT_SECRET).
KODAMA_MODE=local

# Only needed when KODAMA_MODE=cloud.
# Get these from your project dashboard.
KODAMA_PROJECT_ID=
KODAMA_PROJECT_SECRET=

# Daily check-in times (24h HH:MM in your local timezone).
KODAMA_CADENCE_MORNING=08:15
KODAMA_CADENCE_AFTERNOON=13:30
KODAMA_CADENCE_EVENING=21:45

# twitterapi.io key — enables the `watch @handle` feature and the 5-hour
# X digest. Get one at https://twitterapi.io. Optional; if unset, x tools
# stay disabled and kodama still handles journal/tasks/reminders.
KODAMA_TWITTERAPI_KEY=
